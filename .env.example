# ---------------------------------------------------------------------------
# Virtualfactor IT CMDB — environment configuration
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# Consumed by podman-compose.yml and by the Quadlet units in deploy/quadlet/
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=vfcmdb
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=vfcmdb
# Host port that maps to the Postgres container (container always uses 5432)
DB_PORT=5432

# --- Backend (FastAPI) ---
# Host port for the REST API
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins, or * for all
CORS_ORIGINS=*
API_PREFIX=/api/v1

# --- Frontend (React + Nginx) ---
# Host port for the web UI
FRONTEND_PORT=8080

# --- pgAdmin ---
PGADMIN_PORT=5050
# Native pgAdmin variable names (used by both compose and Quadlet)
PGADMIN_DEFAULT_EMAIL=admin@virtualfactor.local
PGADMIN_DEFAULT_PASSWORD=admin
